<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - LMS</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/LMS.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">LMS</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
                        </li>
                        <li class="nav-item">
                            <!-- Выпадающий список для группы -->
                            <select id="groupActions" class="form-select" onchange="navigateToGroupAction()">
                                <option value="" disabled selected>Group Actions</option>
                                <option value="@Url.Action("Add", "Group")">Add group</option>
                                <option value="@Url.Action("Update", "Group")">Update group</option>
                                <option value="@Url.Action("Delete", "Group")">Delete group</option>
                            </select>
                        </li>
                        <li class="nav-item">
                            <!-- Выпадающий список для студентов -->
                            <select id="studentAction" class="form-select" onchange="navigateToStudentAction()">
                                <option value="" disabled selected>Student Actions</option>
                                <option value="@Url.Action("Add", "Student")">Add Student</option>
                                <option value="@Url.Action("Update", "Student")">Update Student</option>
                                <option value="@Url.Action("Delete", "Student")">Delete Student</option>
                            </select>
                        </li>
                        <li class="nav-item"
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2024 - LMS - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        // Скрипт для навигации при выборе опции в combobox
        function navigateToGroupAction() {
            const selectedValue = document.getElementById('groupActions').value;
            if (selectedValue) {
                window.location.href = selectedValue;
            }
        }

        function navigateToStudentAction() {
            const selectedValue = document.getElementById('studentAction').value;
            if (selectedValue) {
                window.location.href = selectedValue;
            }
        }
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
