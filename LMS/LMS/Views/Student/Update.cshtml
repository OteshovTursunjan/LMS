@{
    Layout = "/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "Update Student";
}
<div>
    <h3>Обноваить студент</h3>
    <form method="post">
        <table>
            <tr>
                 <td><p> Введите Id Студента  </p> </td>
                 <td><input type="number" name="ID" /> </td>
            </tr>
            <tr>
                <td><p> Введите имя </p></td>
                <td><input type="text" name="Name" /></td>
            </tr>
            <tr>
                <td><p> Введите id контракта </p></td>
                <td><input type="number" name="groupId" /></td>
            </tr>
            <tr>
                <td><p> Введите Id группы </p></td>
                <td><input type="number" name="ContractId" /></td>
            </tr>
            <tr><td><input type="submit" value="Submit" /></td></tr>
        </table>
    </form>
</div>
